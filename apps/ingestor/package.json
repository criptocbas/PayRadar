{
  "name": "@payradar/ingestor",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch --env-file=../../.env.local src/cli.ts",
    "sync": "tsx --env-file=../../.env.local src/cli.ts sync-catalog",
    "probe": "tsx --env-file=../../.env.local src/cli.ts run-probes",
    "score": "tsx --env-file=../../.env.local src/cli.ts run-scoring",
    "all": "tsx --env-file=../../.env.local src/cli.ts all",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@payradar/schema": "workspace:*",
    "@payradar/scoring-engine": "workspace:*",
    "@supabase/supabase-js": "^2.45.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  }
}
