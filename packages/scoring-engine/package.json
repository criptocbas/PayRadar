{
  "name": "@payradar/scoring-engine",
  "version": "0.1.0",
  "description": "Open-source, deterministic, replayable scoring engine for the PayRadar trust + discovery layer.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./dimensions/reliability": {
      "types": "./dist/dimensions/reliability.d.ts",
      "import": "./dist/dimensions/reliability.js"
    },
    "./dimensions/latency": {
      "types": "./dist/dimensions/latency.d.ts",
      "import": "./dist/dimensions/latency.js"
    },
    "./dimensions/freshness": {
      "types": "./dist/dimensions/freshness.d.ts",
      "import": "./dist/dimensions/freshness.js"
    },
    "./signer": {
      "types": "./dist/signer.d.ts",
      "import": "./dist/signer.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@payradar/schema": "workspace:*",
    "@noble/ed25519": "^2.1.0",
    "@noble/hashes": "^1.5.0"
  },
  "devDependencies": {
    "typescript": "^5.6.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/payradar/payradar.git",
    "directory": "packages/scoring-engine"
  }
}
