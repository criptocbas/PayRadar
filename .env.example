# Supabase — get these from the project settings page
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=ey...
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=ey...

# Long random string. Vercel Cron sends this as the Authorization header.
CRON_SECRET=replace-me-with-32-random-chars

# Oracle signing key. Generate with:
#   pnpm -F @payradar/ingestor exec tsx src/keygen.ts
PAYRADAR_SIGNING_KEY_ID=pr-oracle-2026-q2
PAYRADAR_SIGNING_PRIVATE_KEY_HEX=
PAYRADAR_SIGNING_PUBLIC_KEY_HEX=
# Optional, after a key rotation: kid:hex,kid:hex
PAYRADAR_RETIRED_KEYS=

# Ingestor / probes
PAY_SH_CATALOG_URL=https://pay.sh/api/catalog
PROBE_REGION=us-east-1
